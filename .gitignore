# env & secrets
.env

# python
__pycache__/
*.pyc
.venv/
venv/
.pytest_cache/

# data & storage
data/
backend/data/
*.db
images/

# eval-rag CLI local scratch output (generate --out-dir default; source of truth is MLflow)
backend/eval_runs/

# MLflow local file store (created when MLFLOW_TRACKING_URI trỏ local/không set) — traces
# thật đi vào tracking server infra/, không commit.
mlruns/

# PoC knowledge-graph ontology (backend/poc/kg_ontology): LightRAG working dirs + HTML output
backend/poc/kg_ontology/_poc_storage/

# Qdrant: KHÔNG commit raw storage (preallocate ~hàng trăm MB). Data đi theo git qua
# snapshot: chỉ commit file ổn định qdrant_snapshots/rag_chunks.snapshot, bỏ bản
# timestamped tự sinh + tmp.
qdrant_storage/
qdrant_snapshots/*
!qdrant_snapshots/rag_chunks.snapshot

# node / vite
node_modules/
dist/
.vite/

# os
.DS_Store
Thumbs.db

# claude local settings
.claude/settings.local.json

# meokit — local spec-driven dev kit (kit + artifacts stay local)
meokit/
.claude/skills/
CLAUDE.local.md

# nginx Basic Auth credentials (hash) — secret, created on the VM
infra/nginx/.htpasswd
