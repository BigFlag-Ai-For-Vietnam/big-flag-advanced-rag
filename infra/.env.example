# === nginx (reverse proxy duy nhất vào backend) ===
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# === Qdrant (vector DB của app RAG) ===
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334

# === Postgres (MLflow backend store) ===
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow
POSTGRES_DB=mlflow
POSTGRES_PORT=5432

# === RustFS (S3-compatible artifact store) ===
# Đổi sang secret mạnh cho non-dev: openssl rand -base64 24
RUSTFS_ACCESS_KEY=rustfsadmin
RUSTFS_SECRET_KEY=rustfsadmin
RUSTFS_API_PORT=9000
RUSTFS_CONSOLE_PORT=9001

# === MLflow ===
MLFLOW_PORT=5000
# Bucket lưu artifacts trên RustFS (tạo tự động bởi service createbuckets).
MLFLOW_BUCKET=mlflow
