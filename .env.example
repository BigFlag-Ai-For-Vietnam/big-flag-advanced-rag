# === FPT AI Marketplace (OpenAI-compatible) ===
FPT_API_KEY=

# Base URL cố định của FPT AI Inference
FPT_BASE_URL=https://mkp-api.fptcloud.com

# QUAN TRỌNG: lấy đúng model ID trên https://marketplace.fptcloud.com
# - VLM vision (đọc ảnh page). GLM có dòng vision — confirm ID chính xác trên trang model.
FPT_VLM_MODEL=
# - Chat model (dùng cho contextual chunking + trả lời QA)
FPT_CHAT_MODEL=
# - Embedding model. Gợi ý cho tiếng Việt: Vietnamese_Embedding (~1024d),
#   hoặc bge-m3 (1024d), multilingual-e5-large (1024d), gte-multilingual-base (768d).
FPT_EMBED_MODEL=
# PHẢI khớp số chiều vector của model embedding ở trên (sai -> Qdrant upsert lỗi).
EMBED_DIM=1024

# Prompt caching: FPT tự cache prefix (server-side) — usage trả về cached_tokens.
# Cờ này chỉ điều khiển việc đính cache_control thủ công (Anthropic-style); để false an toàn.
FPT_ENABLE_PROMPT_CACHE=false

# GLM-5.x là model reasoning: nếu bật thinking sẽ ngốn hết max_tokens vào phần "suy nghĩ"
# và trả content rỗng khi max_tokens thấp. Để true để tắt thinking cho tác vụ RAG.
FPT_DISABLE_THINKING=true

# Timeout mỗi request LLM và số retry SDK cho các bước interactive retrieval.
LLM_TIMEOUT=150
INTERACTIVE_LLM_MAX_RETRIES=1
# Token tối đa cho câu định vị contextual chunking (đủ rộng khi đã tắt thinking).
CONTEXTUAL_MAX_TOKENS=500

# Số page parse song song bằng VLM
VLM_MAX_CONCURRENCY=4
# Nếu VLM trả rỗng 1 trang, dùng text-layer PDF (page.extract_text) làm dự phòng.
# Để true giúp không bị document rỗng khi model cấu hình sai vision.
PARSE_TEXT_FALLBACK=true

# Nguồn build catalog (cây entities): "chunks" (từ final_content đã contextual — mặc định,
# mảnh self-contained nhờ câu định vị) hoặc "pages" (từ parsed_text từng trang, giữ heading).
CATALOG_SOURCE=chunks

# === Qdrant (chạy trong stack infra/) ===
# localhost cho backend chạy trên host; trong Docker compose app đã override
# thành http://qdrant:6333 (network rag-infra chung với infra/).
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=rag_chunks

# === Neo4j / Knowledge Graph (chạy trong stack infra/) ===
# localhost cho backend chạy trên host; trong Docker compose app đã override URI
# thành bolt://neo4j:7687 (network rag-infra chung với infra/). USERNAME/PASSWORD PHẢI
# khớp NEO4J_USERNAME/NEO4J_PASSWORD của infra/.env (Neo4j thật chạy ở đó).
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=changeme123
# Bật graph baseline lúc query (assess() nhận thêm bằng chứng đồ thị) — CHỈ bật sau khi đã
# build graph (kg_enable_build=true, chạy ingest xong) và graph_service.stats() không rỗng.
RETRIEVAL_ENABLE_GRAPH=false
RETRIEVAL_GRAPH_CITATION_HOPS=1
RETRIEVAL_GRAPH_CONCEPT_TOP_K=5
RETRIEVAL_GRAPH_MAX_FACTS_PER_SUBGOAL=6
RETRIEVAL_GRAPH_CONCEPT_EMBEDDING_THRESHOLD=0.65
# Bật graph-build lúc ingest (LightRAG + ontology, chạy nền — không chặn Qdrant indexing).
# Chỉ áp dụng cho document category trong KG_CATEGORIES (ontology hiện chỉ verify "van_ban_tuan_thu").
KG_ENABLE_BUILD=false
KG_CATEGORIES=["van_ban_tuan_thu"]
KG_MAX_CONCURRENT_BUILDS=1

# === Storage / DB ===
DB_URL=sqlite:///./data/rag.db
# Gốc lưu blob khi STORAGE_BACKEND=local (PDF gốc + ảnh page).
DATA_DIR=./data

# Backend lưu blob: "local" (đĩa dưới DATA_DIR, mặc định) hoặc "s3" (RustFS / S3-compatible).
STORAGE_BACKEND=local
# --- Chỉ dùng khi STORAGE_BACKEND=s3 ---
# RustFS S3 API. Backend chạy local: http://localhost:9000; trong compose cùng mạng: http://rustfs:9000.
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=rustfsadmin
S3_SECRET_KEY=rustfsadmin
# Bucket riêng cho app (tách khỏi bucket "mlflow" của infra); tự tạo nếu chưa có.
S3_BUCKET=rag-documents
S3_REGION=us-east-1

# === Chunking ===
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# === Retrieval Engine (LangGraph + MCP) ===
# URL của MCP server (Retrieval Engine) — chạy local: http://localhost:8100/mcp;
# trong docker-compose: http://retrieval-mcp:8100/mcp (service backend override giá trị này).
RETRIEVAL_MCP_URL=http://localhost:8100/mcp
# Số bước lặp tối đa của ReAct subgraph (agent<->tools) — chặn loop vô hạn/tốn phí.
RETRIEVAL_AGENT_MAX_STEPS=6
# Bật/tắt từng node deterministic để so sánh ảnh hưởng riêng lẻ (đổi rồi chạy lại là thấy khác biệt).
RETRIEVAL_ENABLE_NORMALIZE=true
RETRIEVAL_ENABLE_REWRITE=true
RETRIEVAL_ENABLE_RERANK=true

# --- Agentic planning (plan -> gather -> assess -> loop) ---
# Bật: tách câu hỏi thành sub-goal, retrieve từng cái, kiểm tra coverage, lặp tới khi đủ /
# hết budget. Tắt -> 1 sub-goal = cả câu hỏi (retrieve 1 lần, không loop).
RETRIEVAL_ENABLE_PLANNING=true
RETRIEVAL_MAX_HOPS=3               # số vòng gather->assess tối đa (budget)
RETRIEVAL_PER_SUBGOAL_K=4         # số chunk lấy mỗi sub-goal mỗi vòng
RETRIEVAL_PLAN_MAX_SUBGOALS=6     # chặn số sub-goal planner sinh ra
RETRIEVAL_COVERAGE_MIN_SCORE=0.35  # ngưỡng điểm coi là bằng chứng (fallback khi assess lỗi)

# --- Hybrid retrieval (dense + BM25) ---
# Bật: mỗi search = dense (Qdrant) + BM25 (keyword từ chunks SQLite) rồi fuse → vá ca tra
# bảng/số/keyword mà dense yếu. Tắt -> dense-only.
RETRIEVAL_ENABLE_HYBRID=true
RETRIEVAL_HYBRID_ALPHA=0.5         # trọng số dense khi fuse (0..1); phần còn lại cho BM25

# --- Versioning / hiệu lực ---
# Bật: loại HẲN văn bản đã hết hiệu lực/bị thay thế (is_active=false) khỏi retrieval (dense + BM25
# + catalog) → câu trả lời luôn dùng bản hiện hành. Tắt (false): tìm cả bản đã hết hiệu lực
# (để demo so sánh RAG có/không versioning cạnh nhau).
RETRIEVAL_EXCLUDE_INACTIVE=true
# === Eval / MLflow ===
# URI MLflow tracking server (stack infra/, cổng 5000).
# Mặc định localhost dành cho CLI eval chạy trên host (python -m eval ...).
# Trong Docker, compose app đã override thành http://mlflow:5000
# (backend nối network rag-infra chung với infra/).
# LƯU Ý macOS: AirPlay Receiver chiếm cổng 5000 trên host — nếu infra/.env đặt
# MLFLOW_PORT=5050 thì đổi URI này thành http://localhost:5050 (không thì eval
# chạy trên host sẽ dính 403 từ AirPlay thay vì MLflow).
MLFLOW_TRACKING_URI=http://localhost:5000
# Tên experiment MLflow chứa các run eval.
MLFLOW_EXPERIMENT=advanced-rag-eval
# --- Tracing (span MLflow cho parsing / embedding / playground) ---
# Bật ghi trace các bước pipeline + QA vào experiment RIÊNG (tách khỏi eval). Best-effort:
# nếu MLflow không kết nối được thì tự tắt trace (probe nhanh), KHÔNG chặn request/pipeline.
# Đặt false khi chạy offline/không có MLflow.
TRACING_ENABLED=true
MLFLOW_TRACE_EXPERIMENT=advanced-rag-traces
# Model ID làm judge cho ragas metrics; để rỗng -> dùng FPT_CHAT_MODEL.
EVAL_JUDGE_MODEL=
# Số worker song song tối đa cho các lời gọi LLM khi eval (an toàn rate-limit FPT).
EVAL_MAX_WORKERS=4
